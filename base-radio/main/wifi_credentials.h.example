/* wifi_credentials.h.example
 *
 * base-radio is the only firmware in this repo that joins a normal Wi-Fi
 * network (it needs an IP address for mDNS + UDP sockets -- see
 * ../README.md). Copy this file to wifi_credentials.h (already in
 * .gitignore, so your real credentials never get committed) and fill in
 * your network's details.
 *
 * IMPORTANT: per the channel-lock caveat documented in main/raw_link.h
 * and ../README.md, your AP's channel must be fixed/configured to match
 * RAW_LINK_CHANNEL (default 6, in main/raw_link.h) in your router's admin
 * settings, or the raw link to bot-radio will not receive frames once
 * base-radio associates.
 */
#ifndef WIFI_CREDENTIALS_H
#define WIFI_CREDENTIALS_H

#define WIFI_SSID "your-network-name"
#define WIFI_PASS "your-network-password"

#endif /* WIFI_CREDENTIALS_H */
